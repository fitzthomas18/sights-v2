[Unit]
Description=SIGHTS - Main
After=network.target

[Service]
Type=exec
WorkingDirectory=/opt/sights/server
ExecStartPre=/bin/bash -c 'rm -f ~/.cache/sights-log.txt'
ExecStart=/opt/sights/server/.venv/bin/gunicorn server:app --log-level info --capture-output --log-file ~/.cache/sights-log.txt -w 2 -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:8000
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
